{
  "manifest_version": 3,
  "name": "Linger",
  "version": "1.0.0",
  "description": "A mindful saving tool for Pinterest — notice what you love as you save.",
  "permissions": ["storage", "activeTab", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "*://*.pinterest.com/*",
    "*://pinterest.com/*",
    "*://*.pinterest.co.uk/*",
    "*://*.pinterest.fr/*",
    "*://*.pinterest.de/*",
    "*://*.pinterest.es/*",
    "*://*.pinterest.it/*",
    "*://*.pinterest.jp/*",
    "*://*.pinterest.pt/*",
    "*://*.pinterest.se/*",
    "*://*.pinterest.mx/*",
    "*://*.pinterest.com.au/*",
    "*://*.pinterest.ca/*",
    "https://i.pinimg.com/*",
    "*://*.zara.com/*",
    "*://*.hm.com/*",
    "*://*.asos.com/*",
    "*://*.uniqlo.com/*",
    "*://*.mango.com/*",
    "*://*.urbanoutfitters.com/*",
    "*://*.nordstrom.com/*",
    "*://*.net-a-porter.com/*",
    "*://*.shopify.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "dashboard/dashboard.html",
    "default_title": "Linger — taste profile",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.pinterest.com/*",
        "*://pinterest.com/*",
        "*://*.pinterest.co.uk/*",
        "*://*.pinterest.fr/*",
        "*://*.pinterest.de/*",
        "*://*.pinterest.es/*",
        "*://*.pinterest.it/*",
        "*://*.pinterest.jp/*",
        "*://*.pinterest.pt/*",
        "*://*.pinterest.se/*",
        "*://*.pinterest.mx/*",
        "*://*.pinterest.com.au/*",
        "*://*.pinterest.ca/*"
      ],
      "js": ["content/pinterest.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.zara.com/*",
        "*://*.hm.com/*",
        "*://*.asos.com/*",
        "*://*.uniqlo.com/*",
        "*://*.mango.com/*",
        "*://*.urbanoutfitters.com/*",
        "*://*.nordstrom.com/*",
        "*://*.net-a-porter.com/*",
        "*://*.shopify.com/*"
      ],
      "js": ["content/shopping.js"],
      "css": ["content/shopping.css"],
      "run_at": "document_idle"
    }
  ]
}
