{
  "manifest_version": 3,
  "name": "Linger",
  "version": "1.0.0",
  "description": "Pinterest tells you what you like. Linger tells you why. Shop slower, more intentionally, and truer to your taste.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/small-logo.svg",
        "icons/full-logo.svg",
        "icons/linger.json"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "*://*.pinterest.com/*",
    "*://pinterest.com/*",
    "*://*.pinterest.co.uk/*",
    "*://*.pinterest.fr/*",
    "*://*.pinterest.de/*",
    "*://*.pinterest.es/*",
    "*://*.pinterest.it/*",
    "*://*.pinterest.jp/*",
    "*://*.pinterest.pt/*",
    "*://*.pinterest.se/*",
    "*://*.pinterest.mx/*",
    "*://*.pinterest.com.au/*",
    "*://*.pinterest.ca/*",
    "https://i.pinimg.com/*",
    "<all_urls>",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_title": "Linger — taste profile",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.pinterest.com/*",
        "*://pinterest.com/*",
        "*://*.pinterest.co.uk/*",
        "*://*.pinterest.fr/*",
        "*://*.pinterest.de/*",
        "*://*.pinterest.es/*",
        "*://*.pinterest.it/*",
        "*://*.pinterest.jp/*",
        "*://*.pinterest.pt/*",
        "*://*.pinterest.se/*",
        "*://*.pinterest.mx/*",
        "*://*.pinterest.com.au/*",
        "*://*.pinterest.ca/*"
      ],
      "js": ["libs/lottie.min.js", "content/pinterest.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*/*"],
      "js": ["content/shopping.js"],
      "css": ["content/shopping.css"],
      "run_at": "document_idle"
    }
  ]
}
